{
  "redirects": [
    {
      "source": "/:path*",
      "has": [{ "type": "host", "value": "peerspectiv.ai" }],
      "destination": "https://www.peerspectiv.ai/:path*",
      "permanent": true
    }
  ],
  "crons": [
    { "path": "/api/cron/reviewer-efficiency", "schedule": "0 2 * * *" },
    { "path": "/api/cron/license-expiry", "schedule": "0 6 * * *" },
    { "path": "/api/cron/cycle-completion", "schedule": "0 6 * * *" },
    { "path": "/api/cron/past-due-reminders", "schedule": "0 9 * * *" }
  ]
}
